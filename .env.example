# Copy to .env and fill in. Then: chmod 600 .env
# --- required ---
BOT_TOKEN=123456:ABC-your-botfather-token

# --- recommended ---
# Comma-separated chat ids the bot may act in. Leave empty to allow all.
# Find your channel id from the log on first run ("update in chat <id>").
ALLOWED_CHAT_IDS=

# --- optional (defaults shown) ---
# CLAUDE_BIN=claude
# MODEL=claude-sonnet-4-6
# CLAUDE_TIMEOUT=180
# MIN_CONTENT_CHARS=500
# MAX_INPUT_CHARS=24000
# HTTP_TIMEOUT=30
# POLL_TIMEOUT=30
